# AMR Detection System - Environment Variables
# Copy this file to .env and configure as needed

# ═══════════════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════════════
MODEL_PATH=Models/best.pt
CONFIDENCE_THRESHOLD=0.4
IOU_THRESHOLD=0.45
MAX_DETECTIONS=50
USE_GPU=true
MODEL_TYPE=yolov8

# ═══════════════════════════════════════════════════
# CAMERA CONFIGURATION
# ═══════════════════════════════════════════════════
DEFAULT_CAMERA_URL=0
ENABLE_STREAMING=true
STREAM_FPS=30
STREAM_TIMEOUT=5
FRAME_WIDTH=640
FRAME_HEIGHT=480

# ═══════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════
LOG_LEVEL=INFO
MAX_LOG_ENTRIES=100
THEME=dark

# ═══════════════════════════════════════════════════
# DATA CONFIGURATION
# ═══════════════════════════════════════════════════
DATA_FOLDER=Dataset/Data
MODELS_FOLDER=Models
OUTPUT_FOLDER=results
TRAIN_RATIO=0.8
VALIDATION_RATIO=0.2

# ═══════════════════════════════════════════════════
# BATCH PROCESSING
# ═══════════════════════════════════════════════════
BATCH_SIZE=8
NUM_WORKERS=4
IMAGE_SIZE=640
AUGMENTATION=true

# Notes:
# - DEFAULT_CAMERA_URL: Use "0" for local webcam, or full URL for IP cameras
# - USE_GPU: Set to "false" if you don't have CUDA/GPU support
# - STREAM_FPS: Higher FPS = higher latency, lower FPS = smoother but delayed
# - LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
